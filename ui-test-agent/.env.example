APP_PORT=8130
APP_ENV=development
LOG_LEVEL=INFO

# gateway (default) | direct (local fast path)
LLM_ROUTING=direct

LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=

MCP_GATEWAY_BASE_URL=http://localhost:8120
MCP_GATEWAY_AUTH_DISABLED=true

LLM_PLANNER_MODEL=deepseek-chat
LLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

KEYCLOAK_TOKEN_URL=http://auth.munish.org/auth/realms/am-preprod-realm/protocol/openid-connect/token
AM_MCP_CLIENT_ID=am-mcp-service
AM_MCP_CLIENT_SECRET=

HEADLESS=true
REPORT_DIR=/tmp/am-ui-test-reports

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
QDRANT_API_KEY=

# Hybrid design review (Qdrant ui_patterns + LLM on drift)
DESIGN_REVIEW_ENABLED=true
DESIGN_SIMILARITY_PASS=0.92
DESIGN_SIMILARITY_REVIEW=0.78
DESIGN_GATE_STRICT=false
DESIGN_BUG_MEMORY_THRESHOLD=0.95
BASELINE_MODE=compare
# CLIP_EMBEDDING_MODEL=
