APP_ENV=local
APP_PORT=8140
LOG_LEVEL=INFO

# LLM — gateway (preprod) or direct (local)
LLM_ROUTING=direct
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=
MCP_GATEWAY_BASE_URL=http://localhost:8120
MCP_GATEWAY_AUTH_DISABLED=true
AM_MCP_CLIENT_ID=am-mcp-service
AM_MCP_CLIENT_SECRET=
KEYCLOAK_TOKEN_URL=

LLM_PLANNER_MODEL=together_ai/meta-llama/Meta-Llama-3-8B-Instruct-Lite
LLM_INTENT_ENABLED=true
LLM_SUMMARY_ENABLED=true

DB_AGENT_READ_ONLY_DEFAULT=true
DB_AGENT_ALLOW_WRITES=false
DB_AGENT_MAX_ROWS=100
DB_AGENT_TIMEOUT_SECONDS=30
DB_AGENT_INTENT_MIN_CONFIDENCE=0.75
DB_AGENT_REQUIRE_BACKEND_FOR_AGENTS=true

MCP_DEPLOYMENT_MODE=self_hosted
MCP_UNIVERSAL_GATEWAY=toolbox
MCP_ENABLED=false
TOOLBOX_TOOLS_FILE=config/toolbox.yaml
TOOLBOX_URL=

POSTGRES_URL=
MONGODB_URI=
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_UI_URL=
KAFKA_UI_CLUSTER=am-preprod
KAFKA_PEEK_MODE=auto
GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
INFLUX_URL=
INFLUX_TOKEN=

LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://langfuse.munish.org
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACE_MAX_OUTPUT_CHARS=8000
